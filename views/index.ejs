<!DOCTYPE html>
<html>
<head>
  <title>Load Balancer Dashboard</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
<main class="dashboard-shell">
  <header class="hero">
    <p class="eyebrow">Real-time Infrastructure Monitor</p>
    <h1>Load Balancer Dashboard</h1>
    <p class="subtext">Track backend health, traffic, and response times with live updates.</p>
    <div class="hero-actions">
      <button id="loadBtn">Generate Load</button>
    </div>
  </header>

  <section class="table-card">
    <h2>Server Status</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Server</th>
            <th>Status</th>
            <th>Connections</th>
            <th>Response Time</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="serverTable"></tbody>
      </table>
    </div>
  </section>

  <section class="chart-card">
    <h2>Recent Health History Trend</h2>
    <div class="chart-wrap">
      <canvas id="chart"></canvas>
    </div>
  </section>

  <section class="detail-grid">
    <article class="table-card">
      <h2>Recent Health History</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Server</th>
              <th>Status</th>
              <th>Latency</th>
              <th>Checked</th>
            </tr>
          </thead>
          <tbody id="historyTable"></tbody>
        </table>
      </div>
    </article>

    <article class="table-card">
      <h2>Backend Config Changes</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Action</th>
              <th>Server</th>
              <th>Git Commit</th>
              <th>At</th>
            </tr>
          </thead>
          <tbody id="configTable"></tbody>
        </table>
      </div>
    </article>
  </section>
</main>

<script src="/socket.io/socket.io.js"></script>

<script>
let chart;
const MAX_TIMELINE_POINTS = 40;


function updateTable(data) {
  const table = document.getElementById("serverTable");
  table.innerHTML = "";

  data.forEach(s => {
    const timeText =
      s.responseTime === 0
        ? "⏳ Waiting..."
        : s.responseTime + " ms";

    const actionBtn = s.isDisconnected
      ? `<button class="mini-btn reconnect-btn" data-action="reconnect" data-url="${s.url}">Reconnect</button>`
      : `<button class="mini-btn disconnect-btn" data-action="disconnect" data-url="${s.url}">Disconnect</button>`;

    table.innerHTML += `
      <tr>
        <td>${s.url}</td>
        <td><span class="status-pill ${s.status}">${s.status}</span></td>
        <td>${s.connections || 0}</td>
        <td>${timeText}</td>
        <td>${actionBtn}</td>
      </tr>
    `;
  });

  bindServerActionButtons();
}

function updateHistoryTable(data) {
  const table = document.getElementById("historyTable");
  table.innerHTML = "";

  data.slice(0, 10).forEach(item => {
    const checkedAt = new Date(item.checkedAt).toLocaleTimeString();
    const latency = item.status === "UP" ? `${item.latencyMs} ms` : "-";

    table.innerHTML += `
      <tr>
        <td>${item.serverUrl}</td>
        <td><span class="status-pill ${item.status}">${item.status}</span></td>
        <td>${latency}</td>
        <td>${checkedAt}</td>
      </tr>
    `;
  });
}

function updateConfigTable(data) {
  const table = document.getElementById("configTable");
  table.innerHTML = "";

  data.slice(0, 10).forEach(item => {
    const changedAt = new Date(item.createdAt).toLocaleTimeString();

    table.innerHTML += `
      <tr>
        <td>${item.action}</td>
        <td>${item.url}</td>
        <td>${item.gitCommit || "unknown"}</td>
        <td>${changedAt}</td>
      </tr>
    `;
  });
}

function bindServerActionButtons() {
  const buttons = document.querySelectorAll(".mini-btn");
  buttons.forEach((btn) => {
    btn.onclick = async () => {
      const action = btn.dataset.action;
      const url = btn.dataset.url;
      const endpoint = action === "disconnect" ? "/disconnect-server" : "/reconnect-server";

      btn.disabled = true;
      const originalLabel = btn.innerText;
      btn.innerText = "Updating...";

      try {
        await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url })
        });
      } catch (err) {
        console.error(err);
      } finally {
        btn.disabled = false;
        btn.innerText = originalLabel;
      }
    };
  });
}

// GRAPH UPDATE
function updateChart(historyData) {
  const timeline = historyData
    .slice(0, MAX_TIMELINE_POINTS)
    .reverse();

  const labels = timeline.map(item => {
    const time = new Date(item.checkedAt).toLocaleTimeString();
    const server = item.serverUrl.split(":").pop();
    return `${time} (${server})`;
  });

  const latencyValues = timeline.map(item => (
    item.status === "UP" ? item.latencyMs : 0
  ));

  const pointColors = timeline.map(item => (
    item.status === "UP" ? "#22d3ee" : "#f43f5e"
  ));

  if (!chart) {
    chart = new Chart(document.getElementById("chart"), {
      type: "line",
      data: {
        labels,
        datasets: [{
          label: "Health Check Latency (ms)",
          data: latencyValues,
          borderColor: "#22d3ee",
          backgroundColor: "rgba(34, 211, 238, 0.18)",
          pointBackgroundColor: pointColors,
          pointBorderColor: pointColors,
          pointRadius: 2.5,
          fill: true,
          tension: 0.35
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: {
          duration: 350
        },
        plugins: {
          legend: {
            labels: {
              color: "#e2e8f0"
            }
          }
        },
        scales: {
          x: {
            ticks: {
              color: "#cbd5e1",
              maxTicksLimit: 6
            },
            grid: {
              color: "rgba(148, 163, 184, 0.2)"
            }
          },
          y: {
            beginAtZero: true,
            ticks: {
              color: "#cbd5e1"
            },
            grid: {
              color: "rgba(148, 163, 184, 0.2)"
            }
          }
        }
      }
    });
  } else {
    chart.data.labels = labels;
    chart.data.datasets[0].data = latencyValues;
    chart.data.datasets[0].pointBackgroundColor = pointColors;
    chart.data.datasets[0].pointBorderColor = pointColors;
    chart.update();
  }
}

//  SOCKET
const socket = io();

socket.on("stats", (data) => {
  updateTable(data);
});

//  FALLBACK
setInterval(async () => {
  try {
    const [statsRes, historyRes, configRes] = await Promise.all([
      fetch("/stats"),
      fetch("/history"),
      fetch("/config-history")
    ]);

    const [statsData, historyData, configData] = await Promise.all([
      statsRes.json(),
      historyRes.json(),
      configRes.json()
    ]);

    updateTable(statsData);
    updateChart(historyData);
    updateHistoryTable(historyData);
    updateConfigTable(configData);
  } catch (err) {
    console.error(err);
  }
}, 2000);

//  BUTTON
document.getElementById("loadBtn").addEventListener("click", async () => {
  const btn = document.getElementById("loadBtn");

  btn.innerText = "⏳ Generating...";
  btn.disabled = true;

  try {
    await fetch("/generate-load");
    btn.innerText = "✅ Done!";
  } catch {
    btn.innerText = "❌ Error!";
  }

  setTimeout(() => {
    btn.innerText = "Generate Load";
    btn.disabled = false;
  }, 2000);
});

//  AUTO LOAD
window.onload = () => {
  fetch("/generate-load");
};

// Keep light background traffic so live graph visibly changes.
setInterval(() => {
  fetch("/generate-load").catch(() => {});
}, 10000);
</script>

</body>
</html>
